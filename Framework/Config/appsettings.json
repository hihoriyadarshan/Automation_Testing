{
  "Environment": "QA",

  "Browser": {
    "Type": "chromium",
    "Headless": false,
    "SlowMo": 0,
    "Channel": "",
    "LaunchTimeout": 30000
  },

  "Application": {
    "BaseUrl": "https://automationexercise.com/"
  },

  "Timeouts": {
    "DefaultTimeout": 30000,
    "NavigationTimeout": 60000,
    "ExpectTimeout": 10000
  },

  "Execution": {
    "Parallel": true,
    "Workers": 2,
    "RetryCount": 1
  },

  "Tracing": {
    "Enabled": true,
    "Screenshots": true,
    "Snapshots": true,
    "Sources": true
  },

  "Video": {
    "Enabled": false,
    "Path": "Reports/Videos"
  },

  "Screenshots": {
    "CaptureOnFailure": true,
    "Path": "Reports/Screenshots"
  },

  "Allure": {
    "ResultsDirectory": "Reports/allure-results"
  }
}